{
    // ────────────────────────────────────────────────────────────
    // PROJECT FORMATTERS & CODE ACTIONS
    // ────────────────────────────────────────────────────────────
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
            "source.fixAll.eslint": "explicit"
        }
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
            "source.fixAll.eslint": "explicit"
        }
    },
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
            "source.fixAll.stylelint": "always"
        }
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[mdx]": {
        "editor.wordWrapColumn": 120,
        "editor.wordWrap": "bounded"
        "editor.wordWrap": "bounded"
    },
    "[markdown]": {
        "editor.wordWrapColumn": 120,
        "editor.wordWrap": "bounded"
    },
    "[postcss]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
            "source.fixAll.stylelint": "always"
        }
    },

    // ────────────────────────────────────────────────────────────
    // FILE EXCLUSIONS (Generated files)
    // ────────────────────────────────────────────────────────────
    "files.exclude": {
        "**/*.css.ts": {
            "when": "$(basename)"
        },
        "1st-gen/packages/**/*.js.map": true,
        "1st-gen/packages/**/*.js": {
            "when": "$(basename).ts"
        },
        "1st-gen/packages/**/*.dev.js": {
            "when": "$(basename).js"
        },
        "1st-gen/packages/**/*.d.ts": {
            "when": "$(basename).ts"
        },
        "1st-gen/tools/**/*.js.map": true,
        "1st-gen/tools/**/*.js": {
            "when": "$(basename).ts"
        },
        "1st-gen/tools/**/*.dev.js": {
            "when": "$(basename).js"
        },
        "1st-gen/tools/**/*.d.ts": {
            "when": "$(basename).ts"
        },
        "**/*.test-vrt.ts": true,
        "projects/**": true,
        "tools/**": true,
        "test/**": true,
        "packages/**": true
    },

    // ────────────────────────────────────────────────────────────
    // PROJECT-SPECIFIC TOOLING
    // ────────────────────────────────────────────────────────────

    // ────────────────────────────────────────────────────────────
    // PROJECT-SPECIFIC TOOLING
    // ────────────────────────────────────────────────────────────
    "typescript.tsdk": "node_modules/typescript/lib",
    "lit-plugin.strict": true,
    // Exclude test files from lit-plugin type binding checks
    // Tests often intentionally use invalid values to verify warning behavior
    "lit-plugin.exclude": ["**/*.test.ts", "**/test/**/*.ts"],
    "eslint.validate": ["javascript", "typescript"],
    "css.validate": false,
    "postcss.validate": false,
    "stylelint.enable": true,
    "stylelint.packageManager": "yarn",
    "stylelint.validate": ["css", "postcss"],

    "prettier.requireConfig": true,

    // ────────────────────────────────────────────────────────────
    // PROJECT DICTIONARY
    // ────────────────────────────────────────────────────────────
    "cSpell.words": [
        "activedescendant",
        "AUTODOCS",
        "checkmark",
        "coachmark",
        "effectful",
        "minifiers",
        "valuetext"
    ],
}
