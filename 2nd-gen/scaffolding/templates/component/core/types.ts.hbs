import type { ElementSize } from '@spectrum-web-components/core/mixins/index.js';

// ──────────────────
//     SHARED
// ──────────────────

/**
 * Valid sizes for the {{dashCase name}}. Narrow or widen this list to match the
 * component's Spectrum 2 spec, then keep the base class `validSizes` in sync.
 */
export const {{constantCase name}}_VALID_SIZES = [
    's',
    'm',
    'l',
    'xl',
] as const satisfies readonly ElementSize[];

// ──────────────────
//     TYPES
// ──────────────────

export type {{pascalCase name}}Size = (typeof {{constantCase name}}_VALID_SIZES)[number];
