import { expect, test } from '@playwright/test';

import { gotoStory } from '../../../utils/a11y-helpers.js';

/**
 * Accessibility tests for the {{titleName name}} component (2nd generation).
 *
 * ARIA snapshot tests validate the accessibility tree structure. aXe WCAG
 * compliance and color contrast validation run via test-storybook (see
 * .storybook/test-runner.ts). Both are included in the `test:a11y` command.
 */

test.describe('{{titleName name}} - ARIA Snapshots', () => {
    test('should have the correct accessibility tree by default', async ({
        page,
    }) => {
        const root = await gotoStory(
            page,
            'components-{{dashCase name}}--overview',
            'swc-{{dashCase name}}'
        );
        // TODO: replace with the expected accessibility tree for this component.
        await expect(root).toMatchAriaSnapshot(`
            - text: {{titleName name}}
        `);
    });
});
