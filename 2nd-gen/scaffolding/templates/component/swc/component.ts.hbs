import { CSSResultArray, html, TemplateResult } from 'lit';
import { classMap } from 'lit/directives/class-map.js';

import { {{pascalCase name}}Base } from '@spectrum-web-components/core/components/{{dashCase name}}';

import styles from './{{dashCase name}}.css';

/**
 * @element swc-{{dashCase name}}
 * @since 2.0.0
 *
 * @cssprop --swc-{{dashCase name}}-background-color - Background color of the {{dashCase name}}.
 */
export class {{pascalCase name}} extends {{pascalCase name}}Base {
    // ──────────────────────────────
    //     RENDERING & STYLING
    // ──────────────────────────────

    public static override get styles(): CSSResultArray {
        return [styles];
    }

    protected override render(): TemplateResult {
        // `size` is reflected to the host attribute by `SizedMixin`, so size is
        // styled via `:host([size="..."])` in CSS, not a modifier class. Add
        // modifier classes below only for variants and states, e.g.:
        //   [`swc-{{pascalCase name}}--${this.variant}`]: this.variant != null,
        return html`
            <div
                class=${classMap({
                    ['swc-{{pascalCase name}}']: true,
                })}
            >
                <slot></slot>
            </div>
        `;
    }
}
