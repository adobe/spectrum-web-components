{
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "composite": true,
    "noEmit": false,
    "outDir": "./dist",
    "paths": {
      "@spectrum-web-components/core/*": ["./*"]
    },
    "rootDir": "./"
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.stories.ts",
    "**/stories/**"
  ],
  "extends": "../../tsconfig.json",
  "include": ["**/*.ts"]
}
